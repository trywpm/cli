root = true

[*]
charset = utf-8
indent_size = 4
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
max_line_length = 80

[*.yml]
quote_type = single

[*.{yml,sh,json}]
indent_size = 2
indent_style = space

[scripts/build/*]
indent_size = 2
indent_style = space
